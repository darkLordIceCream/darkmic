{
  "name": "darkmic",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "type": "module",
  "description": "Phone-as-microphone for PC via Chrome browser | 手机做电脑麦克风",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/index.js",
    "test:audio": "tsx scripts/test-audio.ts",
    "pkg": "pnpm exec pkg dist/index.js --targets node20-win-x64 --output dist/darkmic.exe",
    "package": "pnpm build && pnpm run pkg && node scripts/package-release.mjs"
  },
  "dependencies": {
    "express": "^4.21.0",
    "koffi": "^2.16.2",
    "opusscript": "^0.1.1",
    "qrcode": "^1.5.4",
    "ws": "^8.18.0"
  },
  "pkg": {
    "assets": [
      "node_modules/koffi/build/koffi/**/*.node",
      "node_modules/opusscript/build/opusscript_native_wasm.wasm"
    ]
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.5.0",
    "@yao-pkg/pkg": "^6.19.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
